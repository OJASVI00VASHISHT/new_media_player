{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nova Player",
  "version": "0.1.0",
  "identifier": "com.novaplayer.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: https://asset.localhost http://asset.localhost asset://*",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"]
        }
      }
    },
    "windows": [
      {
        "title": "Nova Player",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true,
        "label": "main"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../vendor/mpv-2.dll": "."
    },
    "externalBin": []
  }
}
